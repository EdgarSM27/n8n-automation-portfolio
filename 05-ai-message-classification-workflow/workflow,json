        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'gpt-4.1-mini', input: [ { role: 'system', content: 'You are an AI assistant specialized in classifying sales prospect messages. Return only valid JSON using the requested schema. Do not include markdown.' }, { role: 'user', content: `Classify this prospect message.\\n\\nName: ${$node['Validar Datos'].json.nombre}\\nEmail: ${$node['Validar Datos'].json.email}\\nPhone: ${$node['Validar Datos'].json.telefono}\\nSource: ${$node['Validar Datos'].json.fuente}\\nMessage: ${$node['Validar Datos'].json.mensaje}\\n\\nReturn a JSON object with: categoria, prioridad, sentimiento, resumen, siguiente_accion.` } ], text: { format: { type: 'json_schema', name: 'lead_message_classification', schema: { type: 'object', additionalProperties: false, properties: { categoria: { type: 'string', enum: ['Solicita precio', 'Solicita informacion', 'Solicita llamada', 'Seguimiento pendiente', 'No calificado', 'Soporte o queja', 'Otro'] }, prioridad: { type: 'string', enum: ['Alta', 'Media', 'Baja'] }, sentimiento: { type: 'string', enum: ['Interesado', 'Neutral', 'Negativo', 'Urgente'] }, resumen: { type: 'string' }, siguiente_accion: { type: 'string' } }, required: ['categoria', 'prioridad', 'sentimiento', 'resumen', 'siguiente_accion'] }, strict: true } } }) }}",
        "options": {}
      },
      "id": "66666666-cccc-4666-8666-666666666666",
      "name": "OpenAI - Clasificar Mensaje",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -320,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "const ai = $node['OpenAI - Clasificar Mensaje'].json;\nlet text = '';\n\nif (ai.output_text) {\n  text = ai.output_text;\n} else if (ai.output?.[0]?.content?.[0]?.text) {\n  text = ai.output[0].content[0].text;\n} else if (ai.choices?.[0]?.message?.content) {\n  text = ai.choices[0].message.content;\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (error) {\n  parsed = {\n    categoria: 'Otro',\n    prioridad: 'Media',\n    sentimiento: 'Neutral',\n    resumen: 'No se pudo parsear correctamente la respuesta de la IA.',\n    siguiente_accion: 'Revisar manualmente la conversación.'\n  };\n}\n\nreturn [\n  {\n    json: {\n      ...$node['Validar Datos'].json,\n      categoria: parsed.categoria,\n      prioridad: parsed.prioridad,\n      sentimiento: parsed.sentimiento,\n      resumen: parsed.resumen,\n      siguiente_accion: parsed.siguiente_accion,\n      ai_raw_response: JSON.stringify(ai)\n    }\n  }\n];"
      },
