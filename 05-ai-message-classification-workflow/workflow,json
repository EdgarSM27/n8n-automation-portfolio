      "webhookId": "ai-message-classification"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst data =\n  input.body && Object.keys(input.body).length > 0\n    ? input.body\n    : input.query && Object.keys(input.query).length > 0\n      ? input.query\n      : input;\n\nconst nombre = data.nombre || data.name || \"\";\nconst email = data.email || data.correo || \"\";\nconst telefono = data.telefono || data.phone || data.celular || \"\";\nconst mensaje = data.mensaje || data.message || \"\";\nconst fuente = data.fuente || data.source || \"Sin fuente\";\n\nreturn [\n  {\n    json: {\n      classification_id: \"CLS-\" + Date.now(),\n      nombre: String(nombre).trim(),\n      email: String(email).toLowerCase().trim(),\n      telefono: String(telefono).trim(),\n      mensaje: String(mensaje).trim(),\n      fuente: String(fuente).trim(),\n      fecha_registro: new Date().toISOString().slice(0, 10),\n      json_original: JSON.stringify(data)\n    }\n  }\n];"
      },
      "id": "22222222-cccc-4222-8222-222222222222",
      "name": "Normalizar Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst errores = [];\n\nif (!item.mensaje || item.mensaje.trim().length < 5) {\n  errores.push(\"Mensaje inválido o vacío\");\n}\n\nif (!item.nombre || item.nombre.trim().length < 2) {\n  errores.push(\"Nombre inválido o vacío\");\n}\n\nreturn [\n  {\n    json: {\n      ...item,\n      valido: errores.length === 0,\n      errores_validacion: errores\n    }\n  }\n];"
      },
      "id": "33333333-cccc-4333-8333-333333333333",
      "name": "Validar Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -800,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "validacion",
              "leftValue": "={{ $json.valido }}",
